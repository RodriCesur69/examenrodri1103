<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Monumentos de Málaga</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .contenedor-principal { height: 600px; }
    </style>
</head>
<body class="bg-light d-flex flex-column vh-100">

    <nav class="navbar navbar-dark bg-primary mb-3 shadow-sm">
        <div class="container-fluid px-4">
            <span class="navbar-brand mb-0 h1">Monumentos de Málaga</span>
            <div>
                <% if (usuario) { %>
                    <span class="text-white me-3 small">Hola, <%= usuario %></span>
                    <a href="/logout" class="btn btn-outline-light btn-sm">Salir</a>
                <% } else { %>
                    <button type="button" class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#modalLogin">
                        Login
                    </button>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4 flex-grow-1">
        <div class="row g-3 contenedor-principal">
            <div class="col-md-8 h-100">
                <div id="mapa" class="h-100 shadow-sm rounded border bg-white"></div>
            </div>
            <div class="col-md-4 h-100">
                <div id="listaLateral" class="h-100 overflow-auto shadow-sm rounded border bg-white"></div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalLogin" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Iniciar Sesión</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form action="/login" method="POST">
                        <div class="mb-3">
                            <label class="form-label small">Usuario</label>
                            <input type="text" name="usuario" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Contraseña</label>
                            <input type="password" name="password" class="form-control" required>
                        </div>
                        <div class="d-flex justify-content-end gap-2">
                            <button type="submit" class="btn btn-primary">Entrar</button>
                            <button type="button" class="btn btn-secondary" data-bs-modal="modal" data-bs-target="#modalLogin" data-bs-dismiss="modal">Cancelar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-primary text-white text-center py-3 mt-3">
        <div class="container">
            <p class="mb-0 small">Examen de Rodrigo - 2DAW - Málaga 2026</p>
        </div>
    </footer>

    <script>
        const usuarioLogueado = <%= usuario ? 'true' : 'false' %>;
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/javascripts/app.js"></script>
</body>
</html>